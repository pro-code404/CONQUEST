NODE_ENV=development
CONQUEST_PORT=3000
CONQUEST_LOG_LEVEL=info

DATABASE_URL=postgresql://conquest:conquest@localhost:5432/conquest
# Set to true to force in-memory persistence (CI default when DATABASE_URL unset)
MEMORY_REPO=false
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

CONQUEST_API_KEY=dev-api-key-change-in-production
