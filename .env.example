NODE_ENV=development
CONQUEST_PORT=3000
CONQUEST_API_PORT=3001
CONQUEST_LOG_LEVEL=info
CONQUEST_PROFILE=development

DATABASE_URL=postgresql://conquest:conquest@localhost:5432/conquest
# Set to true to force in-memory persistence (CI default when DATABASE_URL unset)
MEMORY_REPO=false
REDIS_URL=redis://localhost:6379

APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=24h

CONQUEST_API_KEY=dev-api-key-change-in-production
EMAIL_PROVIDER=console
# Production: resend (preferred) or smtp
RESEND_API_KEY=
EMAIL_FROM=Conquest <onboarding@yourdomain.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FALLBACK_PROVIDER=smtp
