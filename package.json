{
  "name": "conquest",
  "version": "0.1.0",
  "private": true,
  "description": "Conquest — Adaptive Cognitive Intelligence Operating System",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "pnpm --filter @conquest/gateway dev",
    "test": "pnpm -r run test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @conquest/database db:generate",
    "db:migrate": "pnpm --filter @conquest/database db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
