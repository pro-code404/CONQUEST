{
  "name": "@conquest/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && node --watch dist/server.js",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "@conquest/auth": "workspace:*",
    "@conquest/config": "workspace:*",
    "@conquest/core": "workspace:*",
    "@conquest/memory-service": "workspace:*",
    "@conquest/observability": "workspace:*",
    "@conquest/orchestrator": "workspace:*",
    "@conquest/session": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
